	function bind_conn(connparm_list,pro_name,ConnParamItem){
		var flag2 = 0;
		var flag3 = 0;
		if(ConnParamItem != undefined && ConnParamItem.ConnParamName != null){
			ConnParamName = ConnParamItem.ConnParamName
			connparamnew = {
				ConnParamId: -2,
				ConnParamName: ConnParamItem.ConnParamName,
				ConnParamValue: ConnParamItem.ConnParam,
				ConnType: ConnParamItem.ConnMode,
				ServiceName: ConnParamItem.ServiceName
			}
			$.each(connparm_list.data,function(i,item){
				if(item.ConnParamName == ConnParamName){
					flag2 = 1;
					return false;
				}
			});
			if(flag2 == 0 && ConnParamName != "用户填写"){
				connparm_list.data.push(connparamnew); //如果上次连接的连接参数被删除  手动拼一个上次的参数加到connparm_list中
			}
		}else{
			ConnParamName = "";
		}
		var user_name1 = "";
		if(user_type == "null" || user_type == "0"){
			user_name1 = "*";
		}else{
			user_name1 = user_name;
		}
		if(connparm_list.data.length != 0){
			var option_str = "";
		}else{
			var option_str = "<option pid=\"0\" value=\"-1\">用户填写</option>";
		}
		conn_array = [];
		if(quick_link == 0){
			if(pro_array.indexOf(pro_name) > -1){
				var param_tmp = new Array();
				var comm_array = [];
				$.each(recent_reAll_c,function(i,item){
					if(item.ServerUser == user_name1 && item.AppChannel != undefined){
						flag3 = 1;
					}
					$.each(item.ConnParamSet,function(i1,item1) {
						if(item1.AccountName == user_name1 || (item1.AccountName == "任意账号")){
							if(item1.ConnParamId != null){
								comm_array.push(item1.ConnParamId);
							}
						}
					})
				})
				$.each(recent_reAll1.data,function(i,item){
					if(item.HostIP == ip_str){
						$.each(item.ProtocolNameSetAll,function(i1,item1){
							if(item1.ProtocolName == pro_name && item1.Port == GLOBAL_Port){
								var tmp1 = "";
								if(pro_name == "HTTP(S)" || pro_name == "HTTP"){
									if(item1.HostServiceName.split("(").length == 3){
										tmp1 = item1.HostServiceName.split("(")[2].split(")")[0];
									}else{
										tmp1 = undefined;
									}
								}else{
									if(item1.HostServiceName.split("(").length == 2){
										tmp1 = item1.HostServiceName.split("(")[1].split(")")[0];
									}else{
										tmp1 = undefined;
									}
								}
								if(tmp1 != undefined){
									param_tmp.push(tmp1);
								}
							}
						})
					}
				})
			}
			$.each(connparm_list.data,function(i,item){
				if($.inArray(item.ConnParamId,comm_array) < 0 && item.ConnParamName != ConnParamName && ($.inArray(item.ConnParamName,param_tmp && flag3 == 0)) > 0 ) return true;
				if(pro_array.indexOf(pro_name) > -1){
					if(param_tmp.indexOf(item.ConnParamName) > -1 || item.ConnParamName == ConnParamName){
						conn_array.push(item);
						var b = conn_array.length - 1;
						option_str = option_str + '<option pid="'+item.ConnParamId+'" value="'+b+'" text="'+HTMLEncode_txt(item.ConnParamName)+'">'+HTMLEncode_txt(item.ConnParamName)+'</option>';
					}
				}else{
					conn_array.push(item);
					option_str = option_str + '<option pid="'+item.ConnParamId+'" value="'+i+'" text="'+HTMLEncode_txt(item.ConnParamName)+'">'+HTMLEncode_txt(item.ConnParamName)+'</option>';
				}
			});
		}
