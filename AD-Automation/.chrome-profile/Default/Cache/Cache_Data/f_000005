							document.frm.uCode.value=$('#uCode').val();
							document.frm.a0.value=result.a0;
							document.frm.a1.value=login_pass_encode(pwd_new1);
							document.frm.chktime.value=result.chktime;
							document.frm.ht.value=result.htime;
							document.frm.pageflag.value='findpwd' + initaction;
							document.frm.action = '/bhost/init_auth';
							document.frm.submit();
