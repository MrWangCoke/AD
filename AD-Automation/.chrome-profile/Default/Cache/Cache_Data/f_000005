//医信签
function client_yxq(){
	$.ajax({
		url: "/bhost/get_yxq_code",
		type:"POST",
		async: false,
		data:{z1:uCode},
		success:function(result){
			var result=(result);
			if(result.Result== false){
				if(ms == 1) _alert(1,"用户登录","二维码获取失败"+result.info);
			}else{
				//循环获取 状态
				var wa = window.open(result.oauthWindowURL,'_blank');
				
				
				//_getDialog22(result.oauthWindowURL)
				
				_showLoading("请扫二维码登陆....");
				var c = 0;
				
				if_ok_down = setInterval(function(){
					ret = repeat_yxq_code(result.sesstime,result.transactionId);
					if(ret == 1){
						document.frm.bhcode.value=result.sesstime; 
						clearInterval(if_ok_down);
						_closeLoading();
						login_check();
						wa.close();
						return 0;
					}
					list_tmp.push(if_ok_down);
					if(ret == -1 ||  ret == 3 || ret == 4){
						clearInterval(if_ok_down);
						_closeLoading();
						document.frm.bhcode.value=result.sesstime;
						login_check();
						wa.close();
						//_alert(1, "用户登录", "验证PIN码失败", null, null, 0);
						return 0;				
					}
					if(c >=300){
						clearInterval(if_ok_down);
						_closeLoading();
						if(ms == 0){
							login_check();
						}
						else _alert(1, "用户登录", "登录超时", null, null, 0);
						for(var i=0;i<(list_tmp).length;i++){
							clearInterval(list_tmp[i]);
						}
						list_tmp=[];
						wa.close();
						return false;
					}			
					c = c + 1;				
				},1000)
			}
		}
	});
}
function repeat_yxq_code(sesstime,transactionId){
	var ret =0;
	$.ajax({
		url: "/bhost/repeat_yxq_code",
		type:"POST",
		async: false,
		timeout:3,
		data:{z1:sesstime,z2:transactionId},
		success:function(result){
			var result=(result);
			ret = result.oauthStatus;
			
		},error:function(){
			ret= -1;
		}
	});
	return ret;
}

// 根据原文和证书产生认证数据包
// 参数说明：initParam：vctk控件初始化参数 key驱动
// 参数说明：authContent：认证原文 接口 get_original-> 根据认证模块的URL 和 应用标识 获取认证原文
function get_original(){
	$.ajax({
		url: "/bhost/get_original",
		type:"POST",
		async: false,
		data:{z1:uCode},
		success:function(result){
			var result=(result);
			if(result.Result== false ||  result.info==[]){
				key_driver=''
				original='';
				return '';
			}else{
				original = result.info.original;
				key_driver=result.info.key_driver;
				return result.info.key_driver;
			}
		}
	});
}
function detachSignStr(initParam,authContent){
	// 验证认证原文不能为空
	if(authContent == ""){
		if(ms == 1) _alert(1,"用户登录","认证原文不能为空");
		return false;
	}else{
		try{
			JIT_GW_ExtInterface.GetVersion();
		}catch(e){
			if(ms == 1) _alert(1,"用户登录","未安装控件，请进行安装控件");
			return false;
        }
		try{
			JIT_GW_ExtInterface.ClearFilter();
			
			// 初始化vctk控件
		    JIT_GW_ExtInterface.Initialize("",initParam);
			// 控制证书为一个时，不弹出证书选择框
			JIT_GW_ExtInterface.SetChooseSingleCert(1);
			// 同DN情况下优先使用sm2证书
			// JIT_GW_ExtInterface.AddFilter(11,"2");
			// 设置是否强制弹出PIN码
			/*var pinCode = document.getElementById("pinCode").value;
			if("true"== pinCode){
				//加捕获异常的方法为兼容之前老版本插件，如果是老版本插件跳过此方法
				try{
					JIT_GW_ExtInterface.SetForcePinDialog(1);
				}catch(e){
					
				}
			}*/
		}catch(e){
			if(ms == 1) _alert(1,"用户登录","调用方法失败");
			return false;
        }
		 // 生成签名信息 
		var sign_Result = "";
		try{
			sign_Result = JIT_GW_ExtInterface.P7SignString(authContent,true,true);
		}catch(e){
			if(ms == 1) _alert(1,"用户登录","生成签名信息失败");
			return false;
        }
		if(JIT_GW_ExtInterface.GetLastError() !=0){
			if (JIT_GW_ExtInterface.GetLastError() == 3758096386
					|| JIT_GW_ExtInterface.GetLastError() == 2148532334 || JIT_GW_ExtInterface.GetLastError() == 3758096385){
				if(ms == 1) _alert(1,"用户登录","用户取消操作");
				return false;
			}else if (JIT_GW_ExtInterface.GetLastError() == -536870815
					|| JIT_GW_ExtInterface.GetLastError() == 3758096481) {
				if(ms == 1) _alert(1,"用户登录","没有找到有效的证书，如果使用的是KEY，请确认已经插入key");
				return false;
			}else{
				if(ms == 1) alert(JIT_GW_ExtInterface.GetLastErrorMessage());
				return false;
			}
		}
		 // 返回签名结果
		return sign_Result;
		
	}
}
