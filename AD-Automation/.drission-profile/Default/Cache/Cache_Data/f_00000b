function ipv42num(ip) {
	var buf = ip.split(".")
	return (parseInt(buf[0]) << 24 |
			parseInt(buf[1]) << 16 |
			parseInt(buf[2]) << 8 |
			parseInt(buf[3]))>>>0;
}

function ipv62num(ip1) { 
	var ip1_arr = ip1.toLowerCase().split(':');
	var ip_arr = [];
	if (ipReg.test(ip1_arr[ip1_arr.length - 1])) { 
		ip_arr = ip1_arr[ip1_arr.length - 1].split('.');
		ip_arr[0] = parseInt(ip_arr[0]).toString(16);
		ip_arr[0] = (ip_arr[0].length < 2) ? ('0' + ip_arr[0]) : ip_arr[0];
		ip_arr[1] = parseInt(ip_arr[1]).toString(16);
		ip_arr[1] = (ip_arr[1].length < 2) ? ('0' + ip_arr[1]) : ip_arr[1];
		ip_arr[2] = parseInt(ip_arr[2]).toString(16);
		ip_arr[2] = (ip_arr[2].length < 2) ? ('0' + ip_arr[2]) : ip_arr[2];
		ip_arr[3] = parseInt(ip_arr[3]).toString(16);
		ip_arr[3] = (ip_arr[3].length < 2) ? ('0' + ip_arr[3]) : ip_arr[3];
		ip1_arr.pop()
		ip1_arr = ip1_arr.concat([(ip_arr[0] + ip_arr[1]), (ip_arr[2] + ip_arr[3])]);
	}
	for (var i = 0; i < ip1_arr.length; i++) {
		if (ip1_arr[i] == '') {
			while (ip1_arr.length < 8) {
				ip1_arr.splice(i + 1, 0, '0000');
			}
		}
		ip1_arr[i] = ('0000' + ip1_arr[i]).slice(-4);
	}
	return ip1_arr.join('');
}

