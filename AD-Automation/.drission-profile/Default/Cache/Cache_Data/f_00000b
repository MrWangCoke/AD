function CheckIP(ip1) { 
	if (ipReg.test(ip1)) return 'ipv4';
	else if (reg_ipv6.test(ip1)) return 'ipv6';
	else return false;
}

function ipv62ipv4 (ip1){
	ip1=ip1.toLowerCase();
	var ip1_arr=ip1.split('::');
	var ip1_arr2=ip1.split('::ffff:');
	if (ip1.indexOf('::')>=0 && ip1_arr.length==2 && CheckIP(ip1_arr[1])=='ipv4'){
		return ip1_arr[1];
	}
	if (ip1.indexOf('::ffff:')>=0 && ip1_arr2.length==2 && CheckIP(ip1_arr2[1])=='ipv4'){
		return ip1_arr2[1];
	}
	return ip1;
}

