function HTMLEncode(str){
	var newStr = "";
	if(!str){
		return "";
	}
	newStr = str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&apos;").replace(/ /g, "&nbsp;").replace(/\n/g," ");
	return newStr;
}

