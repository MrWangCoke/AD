SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/campus_network_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me

# Optional Redis Streams ticket queue. Keep disabled if Redis is not installed.
APP_TICKET_QUEUE_REDIS_ENABLED=false
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
APP_TICKET_QUEUE_REDIS_STREAM_KEY=tickets:created
APP_TICKET_QUEUE_REDIS_MAX_LEN=10000

# Network tuning defaults for one backend instance.
SERVER_TOMCAT_THREADS_MAX=200
SERVER_TOMCAT_THREADS_MIN_SPARE=20
SERVER_TOMCAT_MAX_CONNECTIONS=8192
SERVER_TOMCAT_ACCEPT_COUNT=200
SERVER_TOMCAT_CONNECTION_TIMEOUT=10s
SERVER_TOMCAT_KEEP_ALIVE_TIMEOUT=30s
SERVER_TOMCAT_MAX_KEEP_ALIVE_REQUESTS=100
SERVER_COMPRESSION_MIN_RESPONSE_SIZE=512B
